{
  "family": "multiserve",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::987569578101:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::987569578101:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "multiserve",
      "image": "987569578101.dkr.ecr.eu-west-3.amazonaws.com/multiserve:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DEBUG",
          "value": "False"
        },
        {
          "name": "DB_ENGINE",
          "value": "postgresql"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-west-3"
        },
        {
          "name": "AWS_STORAGE_BUCKET_NAME",
          "value": "multiserve-user-data"
        }
      ],
      "secrets": [
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/SECRET_KEY"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/DB_NAME"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/DB_USER"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/DB_PASSWORD"
        },
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/DB_HOST"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/AWS_ACCESS_KEY_ID"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-3:987569578101:secret:multiserve/AWS_SECRET_ACCESS_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/multiserve",
          "awslogs-region": "eu-west-3",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
