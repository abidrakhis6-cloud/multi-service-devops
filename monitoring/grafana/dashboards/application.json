{
  "dashboard": {
    "id": null,
    "title": "Application - Django Metrics",
    "tags": ["application", "django", "http"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (RPS)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(django_http_requests_total[5m])",
            "legendFormat": "Requests/sec",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 2,
        "title": "Error Rate (5xx)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(django_http_responses_total{status=~\"5..\"}[5m])",
            "legendFormat": "5xx errors/sec",
            "refId": "A"
          },
          {
            "expr": "rate(django_http_responses_total{status=~\"4..\"}[5m])",
            "legendFormat": "4xx errors/sec",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 0.1}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Latency p95/p99",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(django_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 latency",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, rate(django_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99 latency",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.5},
                {"color": "red", "value": 2}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Response Status Codes",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(rate(django_http_responses_total[5m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ]
  }
}
